RewriteEngine On

# Serve static files directly
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Serve root as home.html
RewriteRule ^/?$ view/home.html [L]

# Handle HTML page requests 
RewriteRule ^(home|login|cadastro-usuario|carrinho|generos|admin|detalhes-livro|cadastrar-livros)\.html$ view/$1.html [L]

# API endpoints - Send directly to public/index.php
RewriteRule ^(generos|usuarios|livros|editoras|desejos|carrinho|login|logout|session|auth|pedido)/?(.*)$ public/index.php [L,QSA]

# Allow direct access to view/ directory
RewriteRule ^view/ - [L]

# Allow direct access to static asset directories
RewriteRule ^(public|css|js|images)/ - [L] 